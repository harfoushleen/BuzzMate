{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "PythonBackend/**/*",
        "outDir": "dist"
      }
    ]
  }
}

{
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": [
      {
        "include": "PythonBackend/**/*.json",
        "watchAssets": true
      },
      {
        "include": "PythonBackend/**/*.py",
        "watchAssets": true
      }
    ]
  }
}
